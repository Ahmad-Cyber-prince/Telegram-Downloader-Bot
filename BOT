async def admin_text(update, ctx):
    uid = update.effective_user.id
    if uid != ADMIN_ID: return
    txt = update.message.text.strip()

    if ctx.user_data.get('app_pid'):
        try:
            months = int(txt)
            if months < 1 or months > 24:
                await update.message.reply_text("❌ بین ۱ تا ۲۴")
                return
            pid = ctx.user_data['app_pid']
            tuid = ctx.user_data['app_uid']
            add_sub(tuid, months)
            sqlite3.connect(DB_PATH).cursor().execute("UPDATE payments SET status='approved', months=?, amount=? WHERE id=?", (months, months*MONTHLY_PRICE, pid))
            sqlite3.connect(DB_PATH).commit()
            await update.message.reply_text(f"✅ {months} ماه تأیید شد.")
            await ctx.bot.send_message(tuid, f"✅ پرداخت تأیید شد!\n⭐ {months} ماه اضافه شد.")
            del ctx.user_data['app_pid'], ctx.user_data['app_uid']
        except: await update.message.reply_text("❌ عدد معتبر بفرست.")
        return

    if ctx.user_data.get('broadcast'):
        users = all_users()
        ok = 0
        for u in users:
            try: await ctx.bot.send_message(u[0], f"📢 پیام همگانی:\n\n{txt}"); ok += 1
            except: pass
        await update.message.reply_text(f"✅ به {ok}/{len(users)} کاربر ارسال شد.")
        del ctx.user_data['broadcast']
        return

    if ctx.user_data.get('search'):
        try:
            u = get_user(int(txt))
            if u:
                ql, label = get_quality(int(txt))
                await update.message.reply_text(
                    f"👤 اطلاعات کاربر\n"
                    f"🆔 {u[0]}\n👤 {u[2]} (@{u[1] or ''})\n"
                    f"📅 عضویت: {u[3]}\n🆓 رایگان: {u[4]}\n"
                    f"⭐ اشتراک: {u[5] or 'ندارد'}\n📊 {label}\n"
                    f"📥 دانلود: {u[6]}\n🚫 {'مسدود' if u[7] else 'فعال'}"
                )
            else: await update.message.reply_text("❌ کاربر پیدا نشد.")
        except: await update.message.reply_text("❌ شناسه نامعتبر.")
        del ctx.user_data['search']
        return

    if ctx.user_data.get('ban'):
        try:
            uid2 = int(txt)
            u = get_user(uid2)
            if u:
                ban_user(uid2, 1 if u[7]==0 else 0)
                await update.message.reply_text(f"✅ کاربر {'مسدود' if u[7]==0 else 'آزاد'} شد.")
            else: await update.message.reply_text("❌ کاربر پیدا نشد.")
        except: await update.message.reply_text("❌ نامعتبر.")
        del ctx.user_data['ban']
        return

    if ctx.user_data.get('cadd'):
        parts = txt.split('|')
        if len(parts) < 2:
            await update.message.reply_text("❌ فرمت صحیح: @id|نام|لینک")
            return
        add_channel(parts[0].strip(), parts[1].strip(), parts[2].strip() if len(parts)>2 else "")
        await update.message.reply_text(f"✅ {parts[0]} اضافه شد.")
        del ctx.user_data['cadd']
        return

    if ctx.user_data.get('crem'):
        remove_channel(txt.strip())
        await update.message.reply_text(f"✅ کانال حذف شد.")
        del ctx.user_data['crem']
        return

async def panel(update, ctx):
    if update.effective_user.id != ADMIN_ID:
        await update.message.reply_text("⛔ فقط ادمین.")
        return
    await update.message.reply_text("🎛️ پنل مدیریت", reply_markup=admin_kb())

async def main():
    os.makedirs(DOWNLOAD_FOLDER, exist_ok=True)
    init_db()
    threading.Thread(target=net_monitor, daemon=True).start()
    asyncio.create_task(queue_worker())

    print("🚀 ربات روشن شد...")
    print(f"📁 دانلود: {DOWNLOAD_FOLDER}")
    print(f"🗄️ دیتابیس: {DB_PATH}")
    print(f"🔵 همزمان: {MAX_CONCURRENT}")

    app = Application.builder().token(TOKEN).build()
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("panel", panel))
    app.add_handler(CallbackQueryHandler(button))
    app.add_handler(MessageHandler(filters.PHOTO, handle_photo))
    app.add_handler(MessageHandler(filters.TEXT & filters.Entity("url"), handle_link))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND & ~filters.Entity("url"), admin_text))
    await app.run_polling()

if __name__ == "__main__":
