class Prog:
    def __init__(self, msg, quality_label):
        self.msg = msg
        self.qlabel = quality_label
        self.t = time.time()
        self.dl = 0
        self.tot = 0
        self.sp = 0
        self.title = ""
    def hook(self, d):
        if d['status'] == 'downloading':
            self.dl = d.get('downloaded_bytes', 0)
            self.tot = d.get('total_bytes') or d.get('total_bytes_estimate', 0)
            self.sp = d.get('speed', 0)
            self.title = (d.get('info_dict', {}) or {}).get('title', '')[:40]
            if time.time() - self.t > 3:
                self.t = time.time()
                asyncio.ensure_future(self.update())
    async def update(self):
        try:
            if self.tot > 0:
                pct = self.dl / self.tot * 100
                bar = "█" * int(pct/5) + "░" * (20 - int(pct/5))
                cur = self.dl / 1048576
                tot = self.tot / 1048576
                spd = self.sp / 1024
                eta = (self.tot - self.dl) / self.sp if self.sp else 0
                await self.msg.edit_text(f"📥 دانلود...\n🎬 {self.title}\n📊 {self.qlabel}\n📈 [{bar}] {pct:.1f}%\n💾 {cur:.1f}/{tot:.1f}MB\n⚡ {spd:.0f}KB/s\n⏱ {int(eta//60)}:{int(eta%60):02d}", parse_mode="Markdown")
        except: pass

def ydl_opts(q):
    opts = {
        'outtmpl': f'{DOWNLOAD_FOLDER}/%(title).100s.%(ext)s',
        'quiet': True,
        'no_warnings': True,
        'format': f'bestvideo[height<={q}]+bestaudio/best[height<={q}]/best',
        'merge_output_format': 'mp4',
        'noplaylist': True,
        'max_filesize': MAX_FILE_SIZE_MB*1048576,
        'socket_timeout': 60,
    }
    return opts

async def process(url, update, msg, uid):
    global active_downloads
    q, label = get_quality(uid)
    p = Prog(msg, f"{label} ({q}p)")
    try:
        os.makedirs(DOWNLOAD_FOLDER, exist_ok=True)
        opts = ydl_opts(q)
        opts['progress_hooks'] = [p.hook]
        loop = asyncio.get_event_loop()
        info = await loop.run_in_executor(None, lambda: yt_dlp.YoutubeDL(opts).extract_info(url, download=True))
        fn = yt_dlp.YoutubeDL(opts).prepare_filename(info)
        if not os.path.exists(fn):
            base = fn.rsplit('.', 1)[0]
            for ext in ['mp4','mkv','webm','mov','avi','mp3','m4a','wav','flac','ogg','jpg','jpeg','png','webp','gif','bmp','tiff']:
                if os.path.exists(f"{base}.{ext}"): fn = f"{base}.{ext}"; break
            else:
                files = [os.path.join(DOWNLOAD_FOLDER, f) for f in os.listdir(DOWNLOAD_FOLDER)]
                if files: fn = max(files, key=os.path.getctime)
                else: raise Exception("فایل دانلود نشد")
        await msg.edit_text("📤 در حال ارسال...")
        ext = fn.split('.')[-1].lower()
        cap = (info.get('title') or '')[:100]
        with open(fn, 'rb') as f:
            if ext in ['mp4','avi','mov','mkv','webm']:
                await update.message.reply_video(f, caption=f"🎬 {cap}", supports_streaming=True)
            elif ext in ['mp3','wav','ogg','m4a','flac']:
                await update.message.reply_audio(f, title=cap)
            elif ext in ['jpg','jpeg','png','webp','bmp','tiff']:
                await update.message.reply_photo(f, caption=f"🖼 {cap}")
            elif ext == 'gif':
                await update.message.reply_animation(f)
            else:
                await update.message.reply_document(f, caption=f"📎 {cap}")
        os.remove(fn)
        await msg.edit_text("✅ دانلود با موفقیت انجام شد!")
        if is_sub(uid): add_dl(uid)
        else: use_free(uid)
    except Exception as e:
        await msg.edit_text(f"❌ خطا: {str(e)[:200]}")
    finally:
        active_downloads -= 1

async def queue_worker():
    global active_downloads
    while True:
        if download_queue and active_downloads < MAX_CONCURRENT:
            url, update, uid = download_queue.popleft()
            active_downloads += 1
            q, label = get_quality(uid)
            msg = await update.message.reply_text(f"🔍 نوبت شما!\n📊 {label}")
            asyncio.create_task(process(url, update, msg, uid))
        await asyncio.sleep(1)

