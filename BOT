def net_monitor():
    fail = 0
    sent = False
    while True:
        try:
            r = subprocess.run(["ping", "-c", "1", "-W", "3", "8.8.8.8"], capture_output=True, text=True, timeout=5)
            if r.returncode == 0:
                if sent: sms("✅ اینترنت وصل شد."); sent = False
                fail = 0
            else: fail += 1
        except: fail += 1
        if fail >= 3 and not sent:
            sms("🚨 اینترنت ربات قطع شد!")
            sent = True
        time.sleep(60)

