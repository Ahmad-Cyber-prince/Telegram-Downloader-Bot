async def check_join(uid, ctx):
    not_joined = []
    for ch in get_channels():
        try:
            m = await ctx.bot.get_chat_member(ch[1], uid)
            if m.status in ['left', 'kicked', 'banned']: not_joined.append(ch)
        except: pass
    return not_joined

