async def handle_link(update, ctx):
    global active_downloads
    url = update.message.text.strip()
    uid = update.effective_user.id
    if not url.startswith("http"): return
    nj = await check_join(uid, ctx)
    if nj:
        kb = []
        for ch in nj:
            link = ch[3] or f"https://t.me/{ch[1].replace('@','')}"
            kb.append([InlineKeyboardButton(f"📢 {ch[2] or ch[1]}", url=link)])
        kb.append([InlineKeyboardButton("✅ عضو شدم", callback_data="jcheck")])
        await update.message.reply_text("⛔ عضو کانال‌ها شوید:", reply_markup=InlineKeyboardMarkup(kb))
        return
    ok, err = can_dl(uid)
    if not ok:
        await update.message.reply_text(err, reply_markup=user_kb())
        return
    q, label = get_quality(uid)
    if active_downloads >= MAX_CONCURRENT:
        download_queue.append((url, update, uid))
        await update.message.reply_text(f"⏳ صف دانلود...\n🔢 نفر {len(download_queue)}\n📊 {label}")
        return
    active_downloads += 1
    msg = await update.message.reply_text(f"🔍 شروع دانلود...\n📊 {label}")
    asyncio.create_task(process(url, update, msg, uid))

