def init_db():
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("CREATE TABLE IF NOT EXISTS users (user_id INTEGER PRIMARY KEY, username TEXT, first_name TEXT, join_date TEXT, free_downloads INTEGER DEFAULT 3, subscription_expire TEXT, total_downloads INTEGER DEFAULT 0, is_banned INTEGER DEFAULT 0)")
    c.execute("CREATE TABLE IF NOT EXISTS payments (id INTEGER PRIMARY KEY AUTOINCREMENT, user_id INTEGER, months INTEGER, amount INTEGER, receipt_file_id TEXT, status TEXT DEFAULT 'pending', date TEXT)")
    c.execute("CREATE TABLE IF NOT EXISTS force_channels (id INTEGER PRIMARY KEY AUTOINCREMENT, channel_id TEXT, channel_name TEXT, invite_link TEXT, is_active INTEGER DEFAULT 1)")
    conn.commit()
    conn.close()

def get_user(uid):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("SELECT * FROM users WHERE user_id=?", (uid,))
    u = c.fetchone()
    conn.close()
    return u

def add_user(uid, username, first_name):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("INSERT OR IGNORE INTO users (user_id, username, first_name, join_date, free_downloads) VALUES (?,?,?,?,?)", (uid, username, first_name, datetime.now().strftime("%Y-%m-%d %H:%M:%S"), FREE_DOWNLOADS))
    conn.commit()
    conn.close()

def can_dl(uid):
    u = get_user(uid)
    if not u: return False, "/start"
    if u[7]: return False, "⛔ مسدود"
    if u[5]:
        if datetime.strptime(u[5], "%Y-%m-%d %H:%M:%S") > datetime.now():
            return True, None
    if u[4] > 0: return True, None
    return False, "❌ دانلود تموم شده"

def use_free(uid):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("UPDATE users SET free_downloads=free_downloads-1, total_downloads=total_downloads+1 WHERE user_id=? AND free_downloads>0", (uid,))
    conn.commit()
    conn.close()

def add_dl(uid):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("UPDATE users SET total_downloads=total_downloads+1 WHERE user_id=?", (uid,))
    conn.commit()
    conn.close()

def is_sub(uid):
    u = get_user(uid)
    return u and u[5] and datetime.strptime(u[5], "%Y-%m-%d %H:%M:%S") > datetime.now()

def get_quality(uid):
    u = get_user(uid)
    if u and u[5]:
        expire = datetime.strptime(u[5], "%Y-%m-%d %H:%M:%S")
        if expire > datetime.now():
            months = max(1, (expire - datetime.strptime(u[3], "%Y-%m-%d %H:%M:%S")).days // 30)
            if months >= 6: return "1080", "👑 Full HD"
            return "720", "⭐ HD"
    return "360", "🆓 پایه"

def add_sub(uid, months):
    u = get_user(uid)
    if u[5]:
        exp = datetime.strptime(u[5], "%Y-%m-%d %H:%M:%S")
        if exp < datetime.now(): exp = datetime.now()
    else:
        exp = datetime.now()
    new_exp = exp + timedelta(days=months*30)
    max_exp = datetime.now() + timedelta(days=MAX_MONTHS*30)
    if new_exp > max_exp: new_exp = max_exp
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("UPDATE users SET subscription_expire=? WHERE user_id=?", (new_exp.strftime("%Y-%m-%d %H:%M:%S"), uid))
    conn.commit()
    conn.close()

